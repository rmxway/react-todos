# Скопируйте в .env.local и заполните. Файл .env.local не коммитится.
# В проекте используется только Firebase Admin (сервер), клиентский SDK не используется.

# === Firebase Admin — из JSON ключа сервисного аккаунта ===
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# NextAuth: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-base64
NEXTAUTH_URL=http://localhost:3000

# Опционально: таймаут сессии в минутах
# SESSION_MAX_AGE_MINUTES=10
